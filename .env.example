PYTHONANYWHERE_USERNAME=your-username
PYTHONANYWHERE_PASSWORD=your-password

# Optional. Use this when your account has more than one web app.
# It can be the domain/app text shown on the Web tab, for example:
# PYTHONANYWHERE_WEBAPP_NAME=yourusername.pythonanywhere.com
PYTHONANYWHERE_WEBAPP_NAME=

# Optional controls.
HEADLESS=true
SLOW_MO_MS=0
PYTHONANYWHERE_BASE_URL=https://www.pythonanywhere.com
